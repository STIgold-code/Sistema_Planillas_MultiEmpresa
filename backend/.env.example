# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/planillas_multiempresa?schema=public"

# JWT Configuration
# IMPORTANTE: Cambiar estos valores por strings aleatorios de al menos 32 caracteres
# Ejemplo para generar: openssl rand -base64 32
JWT_SECRET="CAMBIAR_POR_STRING_ALEATORIO_DE_32_CARACTERES_MINIMO"
JWT_EXPIRES_IN="30m"
JWT_REFRESH_SECRET="CAMBIAR_POR_OTRO_STRING_ALEATORIO_DE_32_CARACTERES"
JWT_REFRESH_EXPIRES_IN="7d"

# App Configuration
PORT=4001
NODE_ENV=development

# Production (Railway)
# FRONTEND_URL="https://tu-frontend.up.railway.app"

# Feature Flags (convención FF_<FLAG>=true|false; ausente = desactivado)
# SUCAMEC: módulo de control de seguridad privada, oculto por decisión de producto.
# Poner en true para reactivar el registro del módulo y sus endpoints.
FF_SUCAMEC=false
