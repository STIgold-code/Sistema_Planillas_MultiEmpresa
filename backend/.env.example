# ─────────────────────────────────────────────────────────────
# Base de datos PostgreSQL
# En Railway: usar la variable de referencia ${{ Postgres.DATABASE_URL }}
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:password@localhost:5432/planillas_multiempresa?schema=public"

# ─────────────────────────────────────────────────────────────
# JWT — generar con: openssl rand -base64 32 (mínimo 32 caracteres)
# ─────────────────────────────────────────────────────────────
JWT_SECRET="CAMBIAR_POR_STRING_ALEATORIO_DE_32_CARACTERES_MINIMO"
JWT_EXPIRES_IN="30m"
JWT_REFRESH_SECRET="CAMBIAR_POR_OTRO_STRING_ALEATORIO_DE_32_CARACTERES"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=development

# URL del frontend para CORS. En Railway: https://<tu-frontend>.up.railway.app
FRONTEND_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Storage Wasabi (S3-compatible) — REQUERIDO para subir/descargar
# fotos y documentos. Sin esto, los uploads fallan en producción.
# ─────────────────────────────────────────────────────────────
UPLOAD_PROVIDER=wasabi
WASABI_ACCESS_KEY="CAMBIAR"
WASABI_SECRET_KEY="CAMBIAR"
WASABI_BUCKET_NAME="CAMBIAR"
WASABI_REGION="us-east-1"
WASABI_ENDPOINT="https://s3.us-east-1.wasabisys.com"

# ─────────────────────────────────────────────────────────────
# Sentry (OPCIONAL) — monitoreo de errores. Si no se setean, el
# runtime funciona igual sin reportar a Sentry.
# ─────────────────────────────────────────────────────────────
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"
# SENTRY_TRACES_SAMPLE_RATE="0.1"

# ─────────────────────────────────────────────────────────────
# Parámetros legales (OPCIONAL) — overrides de los valores por
# defecto del motor. Lo correcto es cargarlos versionados por
# fecha en la tabla `parametros_legales` (seed), no aquí.
# CONFIRMAR TODOS LOS VALORES CON UN CONTADOR para el período vigente.
# ─────────────────────────────────────────────────────────────
# PLANILLA_RMV=1130
# PLANILLA_UIT=5500
# PLANILLA_ASIG_FAMILIAR=113
# PLANILLA_ESSALUD_PCT=0.09
# PLANILLA_ESSALUD_MIN=101.7
# PLANILLA_ONP_PCT=0.13
# PLANILLA_AFP_APORTE_PCT=0.10
# PLANILLA_AFP_SEGURO_PCT=0.0137
