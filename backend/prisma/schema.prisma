// ==================== INVENTARIO DE UNIFORMES ====================

model Proveedor {
  id             Int                     @id @default(autoincrement())
  nombre         String                  @db.VarChar(200)
  ruc            String?                 @db.VarChar(11)
  contacto       String?                 @db.VarChar(150)
  telefono       String?                 @db.VarChar(20)
  email          String?                 @db.VarChar(150)
  direccion      String?                 @db.VarChar(300)
  activo         Boolean                 @default(true)
  empresa_id     Int
  created_at     DateTime                @default(now())
  updated_at     DateTime                @updatedAt
  empresa        Empresa                 @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  ingresos       IngresoInventario[]
  items          ItemInventario[]
  requerimientos RequerimientoUniforme[]

  @@index([empresa_id])
  @@map("proveedores")
}

model TipoUniforme {
  id                     Int                            @id @default(autoincrement())
  nombre                 String                         @db.VarChar(120)
  descripcion            String?                        @db.VarChar(300)
  genero                 GeneroUniforme                 @default(UNISEX)
  precio_referencial     Decimal?                       @db.Decimal(10, 2)
  cantidad_estandar      Int                            @default(1)
  codigo_prefijo         String?                        @db.VarChar(10)
  activo                 Boolean                        @default(true)
  empresa_id             Int
  created_at             DateTime                       @default(now())
  updated_at             DateTime                       @updatedAt
  empresa                Empresa                        @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  items                  ItemInventario[]
  empleado_tallas        EmpleadoTalla[]
  requerimiento_detalles RequerimientoUniformeDetalle[]
  tallas                 TallaTipoUniforme[]
  plantilla_items        PlantillaUniformeItem[]
  caracteristicas        Caracteristica[]

  @@unique([nombre, empresa_id])
  @@index([empresa_id])
  @@map("tipos_uniforme")
}

/// Atributo descriptivo libre que el PO carga en el maestro y se asocia a
/// una o varias prendas (TipoUniforme) — sale en el cargo PDF al proveedor.
/// Ej.: "Drill azul marino M40", "Costura reforzada doble", "Anti-fluido".
model Caracteristica {
  id             Int            @id @default(autoincrement())
  nombre         String         @db.VarChar(120)
  descripcion    String?        @db.VarChar(500)
  activo         Boolean        @default(true)
  empresa_id     Int
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  empresa        Empresa        @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  tipos_uniforme TipoUniforme[]

  @@unique([nombre, empresa_id])
  @@index([empresa_id])
  @@map("caracteristicas")
}

model PlantillaUniforme {
  id             Int                     @id @default(autoincrement())
  nombre         String                  @db.VarChar(120)
  predeterminada Boolean                 @default(false)
  activo         Boolean                 @default(true)
  empresa_id     Int
  created_at     DateTime                @default(now())
  updated_at     DateTime                @updatedAt
  empresa        Empresa                 @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  items          PlantillaUniformeItem[]

  @@unique([nombre, empresa_id])
  @@index([empresa_id])
  @@map("plantillas_uniforme")
}

model PlantillaUniformeItem {
  id               Int               @id @default(autoincrement())
  plantilla_id     Int
  tipo_uniforme_id Int
  cantidad         Int               @default(1)
  plantilla        PlantillaUniforme @relation(fields: [plantilla_id], references: [id], onDelete: Cascade)
  tipo_uniforme    TipoUniforme      @relation(fields: [tipo_uniforme_id], references: [id], onDelete: Cascade)

  @@unique([plantilla_id, tipo_uniforme_id])
  @@index([plantilla_id])
  @@map("plantillas_uniforme_items")
}

model TallaTipoUniforme {
  id               Int          @id @default(autoincrement())
  tipo_uniforme_id Int
  valor            String       @db.VarChar(20)
  orden            Int          @default(0)
  stock_minimo     Int          @default(0)
  tipo_uniforme    TipoUniforme @relation(fields: [tipo_uniforme_id], references: [id], onDelete: Cascade)

  @@unique([tipo_uniforme_id, valor])
  @@index([tipo_uniforme_id])
  @@map("tallas_tipo_uniforme")
}

model IngresoInventario {
  id               Int                    @id @default(autoincrement())
  proveedor_id     Int
  requerimiento_id Int?
  fecha_ingreso    DateTime               @db.Date
  numero_documento String?                @db.VarChar(50)
  observaciones    String?                @db.VarChar(500)
  // Digitalización de factura del proveedor (Flujo 2 — Compras/Factura).
  // Campos opcionales: una compra puede registrarse sin digitalizar factura
  // (compatibilidad con el flujo simple anterior).
  numero_factura   String?                @db.VarChar(50)
  fecha_factura    DateTime?              @db.Date
  monto_total      Decimal?               @db.Decimal(12, 2)
  archivo_url      String?                @db.VarChar(500)
  archivo_nombre   String?                @db.VarChar(200)
  usuario_id       Int
  empresa_id       Int
  created_at       DateTime               @default(now())
  updated_at       DateTime               @updatedAt
  proveedor        Proveedor              @relation(fields: [proveedor_id], references: [id])
  requerimiento    RequerimientoUniforme? @relation(fields: [requerimiento_id], references: [id], onDelete: SetNull)
  usuario          Usuario                @relation(fields: [usuario_id], references: [id])
  empresa          Empresa                @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  items            ItemInventario[]

  @@unique([empresa_id, proveedor_id, numero_factura])
  @@index([empresa_id])
  @@index([proveedor_id])
  @@index([requerimiento_id])
  @@map("ingresos_inventario")
}

model ItemInventario {
  id               Int                              @id @default(autoincrement())
  codigo           String                           @db.VarChar(40)
  tipo_uniforme_id Int
  ingreso_id       Int
  proveedor_id     Int
  entrega_id       Int?
  talla            String                           @db.VarChar(20)
  precio           Decimal                          @db.Decimal(10, 2)
  estado           EstadoItemInventario             @default(DISPONIBLE)
  condicion        CondicionItemInventario          @default(NUEVO)
  empleado_id      Int?
  empresa_id       Int
  created_at       DateTime                         @default(now())
  updated_at       DateTime                         @updatedAt
  tipo_uniforme    TipoUniforme                     @relation(fields: [tipo_uniforme_id], references: [id], onDelete: Restrict)
  ingreso          IngresoInventario                @relation(fields: [ingreso_id], references: [id], onDelete: Restrict)
  proveedor        Proveedor                        @relation(fields: [proveedor_id], references: [id], onDelete: Restrict)
  entrega          EntregaUniforme?                 @relation(fields: [entrega_id], references: [id], onDelete: SetNull)
  empleado         Empleado?                        @relation(fields: [empleado_id], references: [id], onDelete: SetNull)
  empresa          Empresa                          @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  movimientos      MovimientoInventario[]
  descuento_items  SolicitudDescuentoUniformeItem[]
  solicitudes_baja SolicitudBajaItem[]

  @@unique([codigo, empresa_id])
  @@index([empresa_id])
  @@index([tipo_uniforme_id])
  @@index([estado])
  @@index([empleado_id])
  @@index([entrega_id])
  @@index([empresa_id, estado])
  @@index([empresa_id, codigo])
  @@index([empresa_id, estado, tipo_uniforme_id, talla])
  @@map("items_inventario")
}

model EntregaUniforme {
  id               Int              @id @default(autoincrement())
  empleado_id      Int
  fecha_entrega    DateTime         @db.Date
  entregado_por_id Int
  observaciones    String?          @db.VarChar(500)
  empresa_id       Int
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  empleado         Empleado         @relation(fields: [empleado_id], references: [id], onDelete: Restrict)
  entregado_por    Usuario          @relation(fields: [entregado_por_id], references: [id])
  empresa          Empresa          @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  items            ItemInventario[]

  @@index([empresa_id])
  @@index([empleado_id])
  @@map("entregas_uniforme")
}

model MovimientoInventario {
  id              Int                      @id @default(autoincrement())
  item_id         Int
  tipo_movimiento TipoMovimientoInventario
  empleado_id     Int?
  motivo          String?                  @db.VarChar(500)
  usuario_id      Int
  empresa_id      Int
  fecha           DateTime                 @default(now())
  item            ItemInventario           @relation(fields: [item_id], references: [id], onDelete: Restrict)
  usuario         Usuario                  @relation(fields: [usuario_id], references: [id])
  empresa         Empresa                  @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@index([item_id])
  @@index([empresa_id])
  @@index([empresa_id, fecha])
  @@index([empresa_id, tipo_movimiento])
  @@index([empleado_id])
  @@map("movimientos_inventario")
}

model SolicitudDescuentoUniforme {
  id                  Int                              @id @default(autoincrement())
  empleado_id         Int
  motivo              String                           @db.VarChar(500)
  estado              EstadoSolicitudDescuentoUniforme @default(PENDIENTE)
  monto_total         Decimal?                         @db.Decimal(10, 2)
  solicitado_por_id   Int
  resuelto_por_id     Int?
  fecha_resolucion    DateTime?
  observaciones_admin String?                          @db.VarChar(500)
  empresa_id          Int
  created_at          DateTime                         @default(now())
  updated_at          DateTime                         @updatedAt
  empleado            Empleado                         @relation(fields: [empleado_id], references: [id], onDelete: Cascade)
  solicitado_por      Usuario                          @relation("DescuentoUniformeSolicitado", fields: [solicitado_por_id], references: [id])
  resuelto_por        Usuario?                         @relation("DescuentoUniformeResuelto", fields: [resuelto_por_id], references: [id])
  empresa             Empresa                          @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  items               SolicitudDescuentoUniformeItem[]

  @@index([empresa_id])
  @@index([empleado_id])
  @@index([estado])
  @@index([empresa_id, estado])
  @@map("solicitudes_descuento_uniforme")
}

model SolicitudDescuentoUniformeItem {
  id                Int                        @id @default(autoincrement())
  solicitud_id      Int
  item_id           Int
  precio_referencia Decimal                    @db.Decimal(10, 2)
  monto_descuento   Decimal?                   @db.Decimal(10, 2)
  solicitud         SolicitudDescuentoUniforme @relation(fields: [solicitud_id], references: [id], onDelete: Cascade)
  item              ItemInventario             @relation(fields: [item_id], references: [id])

  @@index([solicitud_id])
  @@index([item_id])
  @@map("solicitudes_descuento_uniforme_items")
}

enum EstadoSolicitudBaja {
  PENDIENTE
  APROBADA
  RECHAZADA
}

/// Solicitud de baja de una prenda del almacén (dañada/inservible). El operario
/// la solicita (queda PENDIENTE, la prenda sigue DISPONIBLE) y el admin la
/// aprueba (la prenda pasa a BAJA) o rechaza. El admin también puede dar de baja
/// directo, en cuyo caso la solicitud se crea ya APROBADA.
model SolicitudBajaItem {
  id                  Int                 @id @default(autoincrement())
  item_id             Int
  motivo              String              @db.VarChar(500)
  estado              EstadoSolicitudBaja @default(PENDIENTE)
  solicitado_por_id   Int
  resuelto_por_id     Int?
  fecha_resolucion    DateTime?
  observaciones_admin String?             @db.VarChar(500)
  empresa_id          Int
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  item                ItemInventario      @relation(fields: [item_id], references: [id])
  solicitado_por      Usuario             @relation("BajaItemSolicitada", fields: [solicitado_por_id], references: [id])
  resuelto_por        Usuario?            @relation("BajaItemResuelta", fields: [resuelto_por_id], references: [id])
  empresa             Empresa             @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@index([empresa_id])
  @@index([item_id])
  @@index([estado])
  @@index([empresa_id, estado])
  @@map("solicitudes_baja_item")
}

model EmpleadoTalla {
  id               Int          @id @default(autoincrement())
  empleado_id      Int
  tipo_uniforme_id Int
  talla            String       @db.VarChar(20)
  empresa_id       Int
  updated_at       DateTime     @updatedAt
  empleado         Empleado     @relation(fields: [empleado_id], references: [id], onDelete: Cascade)
  tipo_uniforme    TipoUniforme @relation(fields: [tipo_uniforme_id], references: [id], onDelete: Cascade)
  empresa          Empresa      @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@unique([empleado_id, tipo_uniforme_id, empresa_id])
  @@index([empresa_id])
  @@map("empleados_tallas")
}

model RequerimientoUniforme {
  id               Int                            @id @default(autoincrement())
  nombre           String                         @db.VarChar(200)
  fecha            DateTime                       @db.Date
  estado           EstadoRequerimientoUniforme    @default(BORRADOR)
  usuario_id       Int
  proveedor_id     Int?
  empresa_id       Int
  aprobado_por_id  Int?
  fecha_aprobacion DateTime?
  created_at       DateTime                       @default(now())
  updated_at       DateTime                       @updatedAt
  usuario          Usuario                        @relation(fields: [usuario_id], references: [id])
  proveedor        Proveedor?                     @relation(fields: [proveedor_id], references: [id])
  empresa          Empresa                        @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  detalles         RequerimientoUniformeDetalle[]
