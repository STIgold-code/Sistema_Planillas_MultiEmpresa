model SolicitudExtension {
  id                    Int                      @id @default(autoincrement())
  empresa_id            Int
  periodo_id            Int
  usuario_id            Int
  sesion_tareo_id       Int                      @unique
  motivo                String
  tiempo_solicitado_min Int                      @default(30)
  estado                EstadoSolicitudExtension @default(PENDIENTE)
  aprobado_por_id       Int?
  fecha_solicitud       DateTime                 @default(now())
  fecha_respuesta       DateTime?
  comentario_respuesta  String?                  @db.VarChar(500)
  created_at            DateTime                 @default(now())
  updated_at            DateTime                 @updatedAt
