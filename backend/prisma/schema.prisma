}

model RequerimientoUniformeDetalle {
  id               Int                   @id @default(autoincrement())
  requerimiento_id Int
  empleado_id      Int?
  tipo_uniforme_id Int
  talla            String                @db.VarChar(20)
  cantidad         Int                   @default(1)
  requerimiento    RequerimientoUniforme @relation(fields: [requerimiento_id], references: [id], onDelete: Cascade)
  empleado         Empleado?             @relation(fields: [empleado_id], references: [id], onDelete: SetNull)
  tipo_uniforme    TipoUniforme          @relation(fields: [tipo_uniforme_id], references: [id], onDelete: Restrict)

  @@index([requerimiento_id])
  @@index([empleado_id])
  @@map("requerimientos_uniforme_detalles")
}

model TipoCeseMaestro {
  id               Int             @id @default(autoincrement())
  nombre           String          @db.VarChar(100)
  descripcion      String?         @db.VarChar(300)
  empresa_id       Int
  activo           Boolean         @default(true)
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  solicitudes_cese SolicitudCese[]
  empresa          Empresa         @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@unique([nombre, empresa_id])
  @@map("tipos_cese")
}

model ReporteGenerado {
  id                   Int            @id @default(autoincrement())
  empresa_id           Int
  usuario_id           Int
  codigo_reporte       String         @db.VarChar(50)
  nombre_reporte       String         @db.VarChar(150)
  categoria            String         @db.VarChar(50)
  formato              FormatoReporte
  filtros              Json?
  total_registros      Int            @default(0)
  archivo_url          String?        @db.VarChar(500)
  archivo_nombre       String?        @db.VarChar(200)
  tiempo_generacion_ms Int?
  created_at           DateTime       @default(now())
  empresa              Empresa        @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  usuario              Usuario        @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([empresa_id, created_at(sort: Desc)])
  @@index([empresa_id, codigo_reporte])
  @@index([usuario_id])
  @@map("reportes_generados")
}

