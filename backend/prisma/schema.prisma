  empresa               Empresa                  @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  periodo               PeriodoTareo             @relation(fields: [periodo_id], references: [id], onDelete: Cascade)
  sesion                SesionTareo              @relation(fields: [sesion_tareo_id], references: [id], onDelete: Cascade)
  usuario               Usuario                  @relation("SolicitudExtensionCreada", fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([empresa_id])
  @@index([periodo_id])
  @@index([usuario_id])
  @@index([estado])
  @@map("solicitudes_extension_tareo")
}

model SolicitudCese {
