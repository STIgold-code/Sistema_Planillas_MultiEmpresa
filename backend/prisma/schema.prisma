  id                    Int                 @id @default(autoincrement())
  empresa_id            Int
  periodo_id            Int
  usuario_id            Int
  fecha                 DateTime            @db.Date
  fecha_inicio          DateTime            @default(now())
  fecha_fin             DateTime?
  tiempo_limite_minutos Int
  estado                EstadoSesionTareo   @default(ACTIVA)
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt
  ultimo_heartbeat      DateTime?
  empresa               Empresa             @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  periodo               PeriodoTareo        @relation(fields: [periodo_id], references: [id], onDelete: Cascade)
  usuario               Usuario             @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  solicitud_extension   SolicitudExtension?

  @@index([empresa_id])
  @@index([periodo_id])
  @@index([usuario_id])
  @@index([estado])
  @@index([fecha])
  @@index([ultimo_heartbeat])
