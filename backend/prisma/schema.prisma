generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TokenRevocado {
  id         Int      @id @default(autoincrement())
  token_hash String   @unique @db.VarChar(64)
  usuario_id Int?
  expires_at DateTime
  revoked_at DateTime @default(now())
  usuario    Usuario? @relation(fields: [usuario_id], references: [id])

  @@index([token_hash])
  @@index([expires_at])
  @@map("tokens_revocados")
}

/// Modelo de propiedad por objeto para el almacenamiento de archivos.
/// Cada archivo subido (Wasabi o local) queda vinculado a una empresa para
/// permitir autorizacion cross-tenant al servirlo. La autorizacion al servir
/// se basa en este registro (campo `publico` + `empresa_id`), nunca en el
/// prefijo de la key.
model Archivo {
  id            Int      @id @default(autoincrement())
  /// Key del objeto en el storage (Wasabi o ruta relativa local). Es la
  /// fuente de verdad y se usa para resolver propiedad al servir.
  key           String   @unique @db.VarChar(500)
  empresa_id    Int
  /// Categoria logica del archivo (logos, firmas, documentos, contratos, etc.).
  categoria     String   @db.VarChar(50)
  /// true solo para archivos genuinamente publicos (logos, assets). Las firmas
  /// del representante legal son SIEMPRE privadas aunque compartan prefijo.
  publico       Boolean  @default(false)
  subido_por_id Int?
  mime          String?  @db.VarChar(150)
  size          Int?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  empresa       Empresa  @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  subido_por    Usuario? @relation(fields: [subido_por_id], references: [id], onDelete: SetNull)

  @@index([empresa_id])
  @@index([categoria])
  @@map("archivos")
}

model Empresa {
  id                             Int                          @id @default(autoincrement())
  ruc                            String                       @unique @db.VarChar(11)
  razon_social                   String                       @db.VarChar(200)
  nombre_comercial               String?                      @db.VarChar(200)
  direccion                      String?                      @db.VarChar(300)
  telefono                       String?                      @db.VarChar(20)
  centro_control                 String?                      @db.VarChar(100)
  email                          String?                      @db.VarChar(100)
  representante_legal            String?                      @db.VarChar(200)
  dni_representante              String?                      @db.VarChar(12)
  cargo_representante            String?                      @db.VarChar(100)
  partida_electronica            String?                      @db.VarChar(20)
  logo_url                       String?                      @db.VarChar(500)
  firma_representante_url        String?                      @db.VarChar(500)
  regimen_laboral_default        RegimenLaboral               @default(GENERAL)
  activo                         Boolean                      @default(true)
  created_at                     DateTime                     @default(now())
  updated_at                     DateTime                     @updatedAt
  archivos                       Archivo[]
  areas                          Area[]
  auditorias                     Auditoria[]
  boletas                        Boleta[]
  cargos                         Cargo[]
  clientes                       Cliente[]
  configuracion_tareo            ConfiguracionTareo?
  configuracion_vacaciones       ConfiguracionVacaciones?
  empleados                      Empleado[]
  movimientos_vacacionales       MovimientoVacacional[]
  periodos_tareo                 PeriodoTareo[]
  periodos_vacacionales          PeriodoVacacional[]
  planillas                      Planilla[]
  plantillas_contrato            PlantillaContrato[]
  plantillas_documento           PlantillaDocumento[]
  plantillas_onboarding          PlantillaOnboarding[]
  postulantes                    Postulante[]
  procedencias                   Procedencia[]
  procesos_onboarding            ProcesoOnboarding[]
  reportes_generados             ReporteGenerado[]
  roles                          Rol[]
  entregas_uniforme              EntregaUniforme[]
  ingresos_inventario            IngresoInventario[]
  items_inventario               ItemInventario[]
  movimientos_inventario         MovimientoInventario[]
  proveedores                    Proveedor[]
  solicitudes_descuento_uniforme SolicitudDescuentoUniforme[]
  solicitudes_baja_item          SolicitudBajaItem[]
  empleados_tallas               EmpleadoTalla[]
  requerimientos_uniforme        RequerimientoUniforme[]
  sedes                          Sede[]
  sesiones_tareo                 SesionTareo[]
  solicitudes_anulacion          SolicitudAnulacionContrato[]
  solicitudes_cese               SolicitudCese[]
  solicitudes_extension          SolicitudExtension[]
  solicitudes_vacaciones         SolicitudVacaciones[]
  tareo_justificaciones          TareoJustificacion[]
  tipos_cese                     TipoCeseMaestro[]
  tipos_documento_empleado       TipoDocumentoEmpleado[]
  tipos_evaluacion               TipoEvaluacionMaestro[]
  tipos_uniforme                 TipoUniforme[]
  caracteristicas                Caracteristica[]
  plantillas_uniforme            PlantillaUniforme[]
  usuarios                       Usuario[]
  vacantes                       Vacante[]
  vinculos_laborales             VinculoLaboral[]

  @@map("empresas")
}

model Rol {
  id          Int       @id @default(autoincrement())
  nombre      String    @db.VarChar(100)
  descripcion String?   @db.VarChar(300)
  permisos    String[]  @default([])
  empresa_id  Int
  activo      Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  empresa     Empresa   @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  usuarios    Usuario[]

  @@unique([nombre, empresa_id])
  @@map("roles")
}

model Usuario {
  id                              Int                          @id @default(autoincrement())
  email                           String                       @unique @db.VarChar(150)
  password                        String                       @db.VarChar(255)
  nombre_completo                 String                       @db.VarChar(200)
  activo                          Boolean                      @default(true)
  empresa_id                      Int
  rol_id                          Int
  ultimo_acceso                   DateTime?
  tokens_revocados_at             DateTime?
  created_at                      DateTime                     @default(now())
  updated_at                      DateTime                     @updatedAt
  archivos_subidos                Archivo[]
  auditorias                      Auditoria[]
  boletas_generadas               Boleta[]                     @relation("BoletaGeneradaPor")
  carnets_sucamec_registrados     CarnetSucamec[]
  contratos                       Contrato[]
  documentos_eliminados           EmpleadoDocumento[]          @relation("DocumentoEliminadoPor")
  documentos_subidos              EmpleadoDocumento[]          @relation("DocumentoSubidoPor")
  movimientos                     EmpleadoMovimiento[]
  movimientos_vacacionales        MovimientoVacacional[]
  periodos_cerrados               PeriodoTareo[]               @relation("PeriodoCerradoPor")
  photocheck_logs                 PhotocheckLog[]
  planillas_aprobadas             Planilla[]                   @relation("PlanillaAprobadaPor")
  postulante_docs_eliminados      PostulanteDocumento[]        @relation("PostulanteDocEliminadoPor")
  postulante_docs_subidos         PostulanteDocumento[]        @relation("PostulanteDocSubidoPor")
  evaluaciones_postulante         PostulanteEvaluacion[]
  entregas_uniforme               EntregaUniforme[]
  ingresos_inventario             IngresoInventario[]
  movimientos_inventario          MovimientoInventario[]
  onboarding_responsable          ProcesoOnboarding[]          @relation("OnboardingResponsable")
  reportes_generados              ReporteGenerado[]
  sesiones_tareo                  SesionTareo[]
  solicitudes_anulacion_resueltas SolicitudAnulacionContrato[] @relation("SolicitudAnulacionResuelta")
  solicitudes_anulacion_creadas   SolicitudAnulacionContrato[] @relation("SolicitudAnulacionSolicitada")
  descuentos_uniforme_solicitados SolicitudDescuentoUniforme[] @relation("DescuentoUniformeSolicitado")
  descuentos_uniforme_resueltos   SolicitudDescuentoUniforme[] @relation("DescuentoUniformeResuelto")
  bajas_item_solicitadas          SolicitudBajaItem[]          @relation("BajaItemSolicitada")
  bajas_item_resueltas            SolicitudBajaItem[]          @relation("BajaItemResuelta")
  requerimientos_uniforme         RequerimientoUniforme[]
  solicitudes_cese_resueltas      SolicitudCese[]              @relation("SolicitudCeseResuelta")
  solicitudes_cese_creadas        SolicitudCese[]              @relation("SolicitudCeseSolicitada")
  solicitudes_extension_aprobadas SolicitudExtension[]         @relation("SolicitudExtensionAprobada")
  solicitudes_extension_creadas   SolicitudExtension[]         @relation("SolicitudExtensionCreada")
  solicitudes_vac_aprobadas_jefe  SolicitudVacaciones[]        @relation("SolicitudAprobadaJefe")
  solicitudes_vac_aprobadas_rrhh  SolicitudVacaciones[]        @relation("SolicitudAprobadaRRHH")
  solicitudes_vac_canceladas      SolicitudVacaciones[]        @relation("SolicitudCancelada")
  solicitudes_vac_creadas         SolicitudVacaciones[]        @relation("SolicitudCreadaPor")
  solicitudes_vac_rechazadas      SolicitudVacaciones[]        @relation("SolicitudRechazada")
  tareas_onboarding               TareaEmpleadoOnboarding[]
  tareo_detalle_audits            TareoDetalleAudit[]
  tareo_justificaciones           TareoJustificacion[]
  tokens_revocados                TokenRevocado[]
  empresa                         Empresa                      @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  rol                             Rol                          @relation(fields: [rol_id], references: [id])

  @@map("usuarios")
}

model Auditoria {
  id               Int             @id @default(autoincrement())
  usuario_id       Int?
  usuario_email    String?         @db.VarChar(150)
  accion           AccionAuditoria
  tabla_afectada   String?         @db.VarChar(100)
  registro_id      Int?
  datos_anteriores Json?
  datos_nuevos     Json?
  empresa_id       Int?
  created_at       DateTime        @default(now())
  empresa          Empresa?        @relation(fields: [empresa_id], references: [id])
  usuario          Usuario?        @relation(fields: [usuario_id], references: [id])

  @@index([usuario_id])
  @@index([tabla_afectada, registro_id, created_at(sort: Desc)])
  @@index([empresa_id, created_at(sort: Desc)])
  @@map("auditoria")
}

model Area {
  id                    Int                   @id @default(autoincrement())
  nombre                String                @db.VarChar(100)
  empresa_id            Int
  activo                Boolean               @default(true)
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  empresa               Empresa               @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  empleados             Empleado[]
  plantillas_onboarding PlantillaOnboarding[]
  tareos                Tareo[]
  vacantes              Vacante[]

  @@unique([nombre, empresa_id])
  @@map("areas")
}

model Cargo {
  id                    Int                   @id @default(autoincrement())
  nombre                String                @db.VarChar(100)
  descripcion           String?               @db.VarChar(300)
  empresa_id            Int
  activo                Boolean               @default(true)
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  empresa               Empresa               @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  empleados             Empleado[]
  plantillas_onboarding PlantillaOnboarding[]
  tareos                Tareo[]
  vacantes              Vacante[]

  @@unique([nombre, empresa_id])
  @@map("cargos")
}

model Cliente {
  id                Int        @id @default(autoincrement())
  ruc               String     @db.VarChar(11)
  razon_social      String     @db.VarChar(200)
  nombre_comercial  String?    @db.VarChar(200)
  direccion         String?    @db.VarChar(300)
  telefono          String?    @db.VarChar(20)
  email             String?    @db.VarChar(100)
  contacto_nombre   String?    @db.VarChar(200)
  contacto_telefono String?    @db.VarChar(20)
  contacto_email    String?    @db.VarChar(100)
  empresa_id        Int
  activo            Boolean    @default(true)
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt
  empresa           Empresa    @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  contratos         Contrato[]
  sedes             Sede[]

  @@unique([ruc, empresa_id])
  @@index([empresa_id])
  @@map("clientes")
}

model Banco {
  id                Int        @id @default(autoincrement())
  nombre            String     @unique @db.VarChar(100)
  codigo            String?    @unique @db.VarChar(10)
  activo            Boolean    @default(true)
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt
  empleados_cts     Empleado[] @relation("BancoCTS")
  empleados_haberes Empleado[] @relation("BancoHaberes")

  @@map("bancos")
}

model Procedencia {
  id          Int          @id @default(autoincrement())
  nombre      String       @db.VarChar(100)
  descripcion String?      @db.VarChar(300)
  empresa_id  Int
  activo      Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  postulantes Postulante[]
  empresa     Empresa      @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@unique([nombre, empresa_id])
  @@map("procedencias")
}

model RegimenPensionario {
  id                  Int         @id @default(autoincrement())
  nombre              String      @unique @db.VarChar(100)
  tipo                TipoRegimen
  aporte_obligatorio  Decimal?    @default(0) @db.Decimal(5, 2)
  comision_flujo      Decimal?    @default(0) @db.Decimal(5, 2)
  comision_saldo      Decimal?    @default(0) @db.Decimal(5, 2)
  prima_seguro        Decimal?    @default(0) @db.Decimal(5, 2)
  remuneracion_maxima Decimal?    @default(0) @db.Decimal(10, 2)
  activo              Boolean     @default(true)
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt
  empleados           Empleado[]

  @@map("regimenes_pensionarios")
}

model TipoMarcacion {
  id                   Int            @id @default(autoincrement())
  codigo               String         @unique @db.VarChar(10)
  descripcion          String         @db.VarChar(100)
  color                String?        @db.VarChar(20)
  cuenta_como          String?        @db.VarChar(50)
  horas_default        Int?           @default(8)
  horas_diurnas        Int            @default(0)
  horas_nocturnas      Int            @default(0)
  requiere_calculo     Boolean        @default(false)
  es_laborable         Boolean        @default(true)
  activo               Boolean        @default(true)
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt
  es_feriado_trabajado Boolean        @default(false)
  equivalente_codigo   String?        @db.VarChar(20)
  genera_pago          Boolean        @default(true)
  tareo_detalles       TareoDetalle[]

  @@map("tipos_marcacion")
}

model Departamento {
  id         Int         @id @default(autoincrement())
  nombre     String      @unique @db.VarChar(100)
  created_at DateTime    @default(now())
  provincias Provincia[]

  @@map("departamentos")
}

model Provincia {
  id              Int          @id @default(autoincrement())
  nombre          String       @db.VarChar(100)
  departamento_id Int
  created_at      DateTime     @default(now())
  distritos       Distrito[]
  departamento    Departamento @relation(fields: [departamento_id], references: [id], onDelete: Cascade)

  @@unique([nombre, departamento_id])
  @@map("provincias")
}

model Distrito {
  id           Int          @id @default(autoincrement())
  nombre       String       @db.VarChar(100)
  provincia_id Int
  created_at   DateTime     @default(now())
  provincia    Provincia    @relation(fields: [provincia_id], references: [id], onDelete: Cascade)
  empleados    Empleado[]
  postulantes  Postulante[]

  @@unique([nombre, provincia_id])
  @@map("distritos")
}

model Empleado {
  id                             Int                            @id @default(autoincrement())
  tipo_documento                 TipoDocumento                  @default(DNI)
  numero_documento               String                         @db.VarChar(12)
  apellido_paterno               String                         @db.VarChar(100)
  apellido_materno               String                         @db.VarChar(100)
  nombres                        String                         @db.VarChar(100)
  fecha_nacimiento               DateTime                       @db.Date
  sexo                           SexoTipo
  estado_civil                   String?                        @db.VarChar(20)
  nacionalidad                   String?                        @default("PERUANA") @db.VarChar(50)
  telefono                       String?                        @db.VarChar(20)
  celular                        String?                        @db.VarChar(20)
  email                          String?                        @db.VarChar(100)
  foto_url                       String?                        @db.VarChar(500)
  direccion                      String?                        @db.VarChar(300)
  referencia                     String?                        @db.VarChar(200)
  distrito_id                    Int?
  area_id                        Int?
  cargo_id                       Int?
  sede_id                        Int?
  fecha_ingreso                  DateTime                       @db.Date
  fecha_planilla                 DateTime?                      @db.Date
  fecha_cese                     DateTime?                      @db.Date
  estado                         EstadoEmpleado                 @default(ACTIVO)
  estado_documentacion           EstadoDocumentacion            @default(PENDIENTE)
  sueldo_base                    Decimal                        @default(1130.00) @db.Decimal(10, 2)
  tipo_pago                      TipoPago                       @default(PLANILLA)
  turno                          TurnoTipo                      @default(DIA)
  regimen_pensionario_id         Int?
  cuspp                          String?                        @db.VarChar(20)
  asignacion_familiar            Boolean                        @default(false)
  sctr                           Boolean                        @default(false)
  es_mype                        Boolean                        @default(false)
  bono_productividad             Decimal?                       @db.Decimal(10, 2)
  bono_desempeno                 Decimal?                       @db.Decimal(10, 2)
  bono_movilidad                 Decimal?                       @db.Decimal(10, 2)
  bono_refrigerio                Decimal?                       @db.Decimal(10, 2)
  bono_armado                    Decimal?                       @db.Decimal(10, 2)
  asignacion_cliente             Decimal?                       @db.Decimal(10, 2)
  monto_adelanto                 Decimal?                       @db.Decimal(10, 2)
  banco_haberes_id               Int?
  nro_cuenta_haberes             String?                        @db.VarChar(30)
  cci_haberes                    String?                        @db.VarChar(25)
  banco_cts_id                   Int?
  nro_cuenta_cts                 String?                        @db.VarChar(30)
  cci_cts                        String?                        @db.VarChar(25)
  celular_asignado               String?                        @db.VarChar(20)
  email_asignado                 String?                        @db.VarChar(100)
  estatura                       Decimal?                       @db.Decimal(3, 2)
  peso                           Decimal?                       @db.Decimal(5, 2)
  categoria_licencia             String?                        @db.VarChar(10)
  estudios                       Json?
  capacitaciones                 Json?
  experiencias                   Json?
  empresa_id                     Int
  created_at                     DateTime                       @default(now())
  updated_at                     DateTime                       @updatedAt
  boletas                        Boleta[]
  carnets_sucamec                CarnetSucamec[]
  contratos                      Contrato[]
  vinculos_laborales             VinculoLaboral[]
  documentos_generados           DocumentoGenerado[]
  area                           Area?                          @relation(fields: [area_id], references: [id])
  banco_cts                      Banco?                         @relation("BancoCTS", fields: [banco_cts_id], references: [id])
  banco_haberes                  Banco?                         @relation("BancoHaberes", fields: [banco_haberes_id], references: [id])
  cargo                          Cargo?                         @relation(fields: [cargo_id], references: [id])
  distrito                       Distrito?                      @relation(fields: [distrito_id], references: [id])
  empresa                        Empresa                        @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  regimen_pensionario            RegimenPensionario?            @relation(fields: [regimen_pensionario_id], references: [id])
  sede                           Sede?                          @relation(fields: [sede_id], references: [id])
  documentos                     EmpleadoDocumento[]
  familiares                     EmpleadoFamiliar[]
  movimientos                    EmpleadoMovimiento[]
  movimientos_vacacionales       MovimientoVacacional[]
  periodos_vacacionales          PeriodoVacacional[]
  photocheck_logs                PhotocheckLog[]
  planilla_detalles              PlanillaDetalle[]
  postulante_origen              Postulante?
  procesos_onboarding            ProcesoOnboarding[]
  mentoria_onboarding            ProcesoOnboarding[]            @relation("OnboardingMentor")
  entregas_uniforme              EntregaUniforme[]
  items_inventario               ItemInventario[]
  solicitudes_descuento_uniforme SolicitudDescuentoUniforme[]
  empleado_tallas                EmpleadoTalla[]
  requerimiento_detalles         RequerimientoUniformeDetalle[]
  solicitudes_anulacion          SolicitudAnulacionContrato[]
  solicitudes_cese               SolicitudCese[]
  solicitudes_vacaciones         SolicitudVacaciones[]
  tareos                         Tareo[]

  @@unique([numero_documento, empresa_id])
  @@index([empresa_id])
  @@index([area_id])
  @@index([sede_id])
  @@index([distrito_id])
  @@index([estado])
  @@index([numero_documento])
  @@index([empresa_id, estado])
  @@map("empleados")
}

model EmpleadoFamiliar {
  id                Int           @id @default(autoincrement())
  empleado_id       Int
  parentesco        String        @db.VarChar(50)
  nombres_apellidos String        @db.VarChar(200)
  tipo_documento    TipoDocumento @default(DNI)
  numero_documento  String?       @db.VarChar(12)
  fecha_nacimiento  DateTime?     @db.Date
  telefono          String?       @db.VarChar(20)
  es_dependiente    Boolean       @default(false)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  empleado          Empleado      @relation(fields: [empleado_id], references: [id], onDelete: Cascade)

  @@index([empleado_id])
  @@map("empleados_familiares")
}

model TipoDocumentoEmpleado {
  id                    Int                   @id @default(autoincrement())
  codigo                String                @db.VarChar(20)
  nombre                String                @db.VarChar(100)
  descripcion           String?               @db.VarChar(300)
  es_obligatorio        Boolean               @default(false)
  aplica_seleccion      Boolean               @default(false)
  aplica_rrhh           Boolean               @default(false)
  dias_alerta           Int?
  orden                 Int                   @default(0)
  activo                Boolean               @default(true)
  empresa_id            Int
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  tipo_vigencia         TipoVigenciaDocumento @default(SIN_FECHAS)
  documentos            EmpleadoDocumento[]
  postulante_documentos PostulanteDocumento[]
  empresa               Empresa               @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@unique([codigo, empresa_id])
  @@index([empresa_id])
  @@map("tipos_documento_empleado")
}

model EmpleadoDocumento {
  id                         Int                     @id @default(autoincrement())
  empleado_id                Int
  tipo_documento_empleado_id Int?
  descripcion                String?                 @db.VarChar(300)
  archivo_url                String                  @db.VarChar(500)
  archivo_nombre             String?                 @db.VarChar(200)
  fecha_emision              DateTime?               @db.Date
  fecha_vencimiento          DateTime?               @db.Date
  fecha_carga                DateTime                @default(now())
  created_at                 DateTime                @default(now())
  updated_at                 DateTime                @updatedAt
  origen                     OrigenDocumentoEmpleado @default(RRHH)
  version                    Int                     @default(1)
  es_version_vigente         Boolean                 @default(true)
  documento_origen_id        Int?
  motivo_nueva_version       String?                 @db.VarChar(500)
  subido_por_id              Int?
  eliminado                  Boolean                 @default(false)
  eliminado_en               DateTime?
  eliminado_por_id           Int?
  motivo_eliminacion         String?                 @db.VarChar(500)
  carnets_sucamec            CarnetSucamec[]
  documento_origen           EmpleadoDocumento?      @relation("VersionChain", fields: [documento_origen_id], references: [id], onDelete: Restrict)
  versiones                  EmpleadoDocumento[]     @relation("VersionChain")
  eliminado_por              Usuario?                @relation("DocumentoEliminadoPor", fields: [eliminado_por_id], references: [id])
