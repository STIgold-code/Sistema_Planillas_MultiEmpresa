# URL del backend (API). En local apunta al backend en el puerto 4001.
# En Railway: https://<tu-backend>.up.railway.app
# IMPORTANTE: NEXT_PUBLIC_* se inyecta en BUILD time, no en runtime.
NEXT_PUBLIC_API_URL="http://localhost:4001"

# Sentry (OPCIONAL) — si no se setea, el build y el runtime funcionan igual.
# NEXT_PUBLIC_SENTRY_DSN=""
